{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vaexcore studio",
  "version": "0.1.0",
  "identifier": "com.vaexcore.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vaexcore studio",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "Local streaming and recording control core",
    "longDescription": "vaexcore studio is a local-first streaming, recording, and app integration control system."
  }
}
