{
  "name": "vaexcore-studio",
  "version": "0.1.0",
  "private": true,
  "description": "macOS-first desktop control system for streaming, recording, and local app integrations.",
  "workspaces": [
    "apps/desktop",
    "packages/shared-types"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev -w apps/desktop",
    "tauri": "npm run tauri -w apps/desktop",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:rust": "cargo test --workspace"
  },
  "engines": {
    "node": ">=20"
  }
}

