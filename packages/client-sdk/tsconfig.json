{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "paths": {
      "@vaexcore/shared-types": ["../shared-types/src"]
    },
    "rootDir": "src",
    "strict": true,
    "target": "ES2022"
  },
  "include": ["src"],
  "references": [{ "path": "../shared-types" }]
}
